      '<div class="filters"><input type="search" id="gov-locks-search" placeholder="Filter locks..." value="'+esc(state.govLocksSearch)+'"></div>'+
      '<table id="gov-locks-table"><thead><tr><th>Name</th><th>Level</th><th>Scope</th></tr></thead><tbody>'+lockBody+'</tbody></table>');
  }

  document.getElementById('view').innerHTML = sections.join('') || '<div class="empty">No governance data was collected.</div>';

