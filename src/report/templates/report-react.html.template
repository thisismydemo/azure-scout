    }).join('') || '<tr><td colspan="3" class="empty">No budgets match the current filter.</td></tr>';
    sections.push('<div class="section-title">Budgets</div>'+
      '<div class="filters"><input type="search" id="gov-budgets-search" placeholder="Filter budgets..." value="'+esc(state.govBudgetsSearch)+'"></div>'+
      '<table id="gov-budgets-table"><thead><tr><th>Name</th><th>Amount</th><th>Category</th></tr></thead><tbody>'+budgetBody+'</tbody></table>');
  }

  // ---- resource locks table (AB#391) ----
  if(ResourceLocks.length){
    var lockRows = ResourceLocks.filter(function(l){
      var q = state.govLocksSearch.toLowerCase();
      if(!q) return true;
      return (l.name||'').toLowerCase().indexOf(q) !== -1;
    });
    var lockBody = lockRows.map(function(l, i){
      var scope = l.resourceGroup || l.id || '';
      return '<tr class="clickable-row" data-idx="'+i+'"><td>'+esc(l.name)+'</td><td>'+esc2(propOrTop(l, 'level'))+'</td><td>'+truncateMiddle(scope, 44)+'</td></tr>';
    }).join('') || '<tr><td colspan="3" class="empty">No resource locks match the current filter.</td></tr>';
