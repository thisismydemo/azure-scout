// ---- Topology (AB#376, AB#377, AB#378, AB#390, AB#387) ----
// Hand-rolled inline SVG (no vis.js/CDN — nothing to fetch, matches this
// file's existing "no build step, no external UMD bundle" vanilla-JS model).
// Coordinates are a deterministic per-VNet column layout, not a physics
// layout: one column per VNet (subnets stacked below it, a dashed "peered
// VNet(s)" ghost node above it when peeringCount > 0, and a dashed "VMs in
// this resource group" aggregate node beside it when a VM shares the VNet's
// resourceGroup+subscriptionId — collect.json does not carry a VM->subnet or
// peering-target linkage, so both are drawn as honest aggregates/stubs
// rather than fabricated precise edges).
var topoNodes = [];   // rebuilt on every renderTopology() call; node.id -> full record for the panel + drag/zoom math
function buildTopology(){
  var nodes = []; var edges = [];
  var colW = 300, colX0 = 40, vnetY = 140, vnetW = 170, vnetH = 54;
  var vmGroupCounts = {};
  VMs.forEach(function(vm){
    var key = (vm.resourceGroup||'') + '|' + (vm.subscriptionId||'');
    vmGroupCounts[key] = (vmGroupCounts[key] || 0) + 1;
  });
  VNets.forEach(function(v, i){
    var colX = colX0 + i * colW;
    var vnetId = 'vnet-' + i;
    nodes.push({ id: vnetId, type: 'vnet', x: colX, y: vnetY, w: vnetW, h: vnetH,
      label: v.name, data: v,
      fields: [ fld('Name', v.name), fld('Resource group', v.resourceGroup), fld('Subscription', v.subscriptionId),
        fld('Peering count', v.peeringCount), fld('DDoS protection', v.ddosEnabled === true ? 'Enabled' : (v.ddosEnabled === false ? 'Disabled' : null)) ] });

    if(v.peeringCount){
      var peerId = vnetId + '-peer';
      nodes.push({ id: peerId, type: 'peer', x: colX, y: vnetY - 100, w: vnetW, h: 40,
        label: v.peeringCount + ' peered VNet' + (v.peeringCount === 1 ? '' : 's'), data: v,
        fields: [ fld('VNet', v.name), fld('Peering count', v.peeringCount),
          fld('Note', 'Peered VNet identities are not collected (only the peering count) — this is an aggregate stub, not a specific target.') ] });
      edges.push({ from: vnetId, to: peerId, dashed: true });
    }

    var rgKey = (v.resourceGroup||'') + '|' + (v.subscriptionId||'');
    var vmCount = vmGroupCounts[rgKey];
    if(vmCount){
      var vmId = vnetId + '-vms';
      nodes.push({ id: vmId, type: 'vmgroup', x: colX + vnetW + 20, y: vnetY, w: 130, h: vnetH,
        label: vmCount + ' VM' + (vmCount === 1 ? '' : 's') + ' in RG', data: { resourceGroup: v.resourceGroup, subscriptionId: v.subscriptionId, count: vmCount },
        fields: [ fld('Resource group', v.resourceGroup), fld('Subscription', v.subscriptionId), fld('VM count', vmCount),
          fld('Note', 'Grouped by matching resource group — collect.json does not carry a VM-to-subnet mapping, so individual VM-to-subnet edges are not drawn.') ] });
      edges.push({ from: vnetId, to: vmId, dashed: true });
    }

    var mySubnets = Subnets.filter(function(s){ return s.vnet === v.name; });
    mySubnets.forEach(function(s, j){
      var subnetId = vnetId + '-subnet-' + j;
      nodes.push({ id: subnetId, type: 'subnet', x: colX, y: vnetY + 100 + j * 64, w: vnetW, h: 48,
        label: s.subnet, data: s,
        fields: [ fld('Subnet', s.subnet), fld('VNet', s.vnet), fld('Prefix', s.prefix),
          fld('Total IPs', s.total), fld('Used', s.used), fld('Utilization %', s.ipUtilizationPct) ] });
      edges.push({ from: vnetId, to: subnetId, dashed: false });
    });
  });
  return { nodes: nodes, edges: edges };
}

function topoTransformStyle(){
  return 'transform:translate('+state.topo.x+'px,'+state.topo.y+'px) scale('+state.topo.k+');transform-origin:0 0;';
}
function applyTopoTransform(){
  var el = document.getElementById('topo-content');
  if(el) el.setAttribute('style', topoTransformStyle());
}
function clamp(v, lo, hi){ return Math.max(lo, Math.min(hi, v)); }

function renderTopology(){
  var topo = buildTopology();
  topoNodes = topo.nodes;

  var svgMarkup = '';
  if(topo.nodes.length){
    var maxX = 0, maxY = 0;
    topo.nodes.forEach(function(n){ maxX = Math.max(maxX, n.x + n.w); maxY = Math.max(maxY, n.y + n.h); });
    var byId = {}; topo.nodes.forEach(function(n){ byId[n.id] = n; });
    var lines = topo.edges.map(function(e){
      var a = byId[e.from], b = byId[e.to];
      if(!a || !b) return '';
      var x1 = a.x + a.w/2, y1 = a.y + a.h/2, x2 = b.x + b.w/2, y2 = b.y + b.h/2;
      return '<line class="topo-edge'+(e.dashed?' dashed':'')+'" x1="'+x1+'" y1="'+y1+'" x2="'+x2+'" y2="'+y2+'"></line>';
    }).join('');
    var nodeMarkup = topo.nodes.map(function(n){
      return '<g class="topo-node '+n.type+'" data-node-id="'+esc(n.id)+'">'+
        '<rect x="'+n.x+'" y="'+n.y+'" width="'+n.w+'" height="'+n.h+'" rx="6"></rect>'+
        '<text x="'+(n.x+10)+'" y="'+(n.y+n.h/2+4)+'">'+esc(String(n.label).length > 22 ? String(n.label).slice(0,21)+'…' : n.label)+'</text>'+
        '</g>';
    }).join('');
    svgMarkup = '<svg id="topo-content" width="'+(maxX+40)+'" height="'+(maxY+40)+'" style="'+topoTransformStyle()+'">'+lines+nodeMarkup+'</svg>';
  }

  function invTable(title, rows, cols, rowFn, note){
    if(!rows) return '';
    var head = '<tr>' + cols.map(function(c){ return '<th>'+esc(c)+'</th>'; }).join('') + '</tr>';
    var body = rows.map(rowFn).join('') || ('<tr><td colspan="'+cols.length+'" class="empty">None found.</td></tr>');
    return '<div class="subsection-title">'+esc(title)+'</div>'+
      (note ? '<div class="empty">'+esc(note)+'</div>' : '')+
      '<table class="topo-inv-table" data-title="'+esc(title)+'"><thead>'+head+'</thead><tbody>'+body+'</tbody></table>';
  }

  var firewallsHtml = invTable('Azure Firewalls', Firewalls, ['Name','Resource group','Subscription','SKU'], function(f, i){
    return '<tr class="clickable-row" data-kind="fw" data-idx="'+i+'"><td>'+esc(f.name)+'</td><td>'+esc(f.resourceGroup)+'</td><td>'+truncateMiddle(f.subscriptionId,18)+'</td><td>'+esc(f.sku)+'</td></tr>';
  }, Firewalls && Firewalls.length ? 'Rule-collection data (Microsoft.Network/firewallPolicies) is not collected in collect.json — showing firewall resource properties only. Click a row for details.' : null);

  var vpnHtml = invTable('VPN gateways', VpnGateways, ['Name','Resource group','Type','SKU','Active-active'], function(v, i){
    return '<tr class="clickable-row" data-kind="vpn" data-idx="'+i+'"><td>'+esc(v.name)+'</td><td>'+esc(v.resourceGroup)+'</td><td>'+esc(v.gatewayType)+'</td><td>'+esc(v.sku)+'</td><td>'+(v.activeActive===true?'Yes':(v.activeActive===false?'No':'—'))+'</td></tr>';
  });

  var peHtml = invTable('Private endpoints', PrivateEndpoints, ['Name','Resource group','Target provider','Target type'], function(p, i){
    return '<tr class="clickable-row" data-kind="pe" data-idx="'+i+'"><td>'+esc(p.name)+'</td><td>'+esc(p.resourceGroup)+'</td><td>'+esc(p.targetProvider)+'</td><td>'+esc(p.targetType)+'</td></tr>';
  });

  document.getElementById('view').innerHTML =
    '<div class="section-title">VNet topology</div>'+
    '<div class="topo-toolbar">'+
      '<button id="topo-reset">Reset view</button>'+
      '<button id="topo-fit">Fit to screen</button>'+
      '<div class="topo-legend">'+
        '<span><i style="background:var(--steel)"></i>VNet</span>'+
        '<span><i style="background:#6a9cd0"></i>Subnet</span>'+
        '<span><i style="background:#fff;border:1px dashed var(--gray)"></i>Peered VNets (count only)</span>'+
        '<span><i style="background:#fff;border:1px dashed var(--green)"></i>VMs (same resource group)</span>'+
      '</div>'+
    '</div>'+
    '<div class="topo-viewport" id="topo-viewport">'+
      (topo.nodes.length ? svgMarkup : '<div class="topo-empty empty">No virtual networks were collected.</div>')+
    '</div>'+
    firewallsHtml + vpnHtml + peHtml;

  // ---- pan / zoom / reset / fit (AB#378) ----
  var viewport = document.getElementById('topo-viewport');
  if(viewport && topo.nodes.length){
    var drag = null;
    viewport.addEventListener('mousedown', function(e){
      drag = { mx: e.clientX, my: e.clientY, tx: state.topo.x, ty: state.topo.y };
      viewport.classList.add('dragging');
    });
    window.addEventListener('mousemove', function(e){
      if(!drag) return;
      state.topo.x = drag.tx + (e.clientX - drag.mx);
      state.topo.y = drag.ty + (e.clientY - drag.my);
      applyTopoTransform();
    });
    window.addEventListener('mouseup', function(){ drag = null; viewport.classList.remove('dragging'); });
    viewport.addEventListener('wheel', function(e){
      e.preventDefault();
      var rect = viewport.getBoundingClientRect();
      var mx = e.clientX - rect.left, my = e.clientY - rect.top;
      var newK = clamp(state.topo.k * (e.deltaY < 0 ? 1.1 : 1/1.1), 0.3, 3);
      state.topo.x = mx - (mx - state.topo.x) * (newK / state.topo.k);
      state.topo.y = my - (my - state.topo.y) * (newK / state.topo.k);
      state.topo.k = newK;
      applyTopoTransform();
    }, { passive: false });

    document.getElementById('topo-reset').onclick = function(){
      state.topo = { x: 40, y: 40, k: 1 };
      applyTopoTransform();
    };
    document.getElementById('topo-fit').onclick = function(){
      var minX = Infinity, minY = Infinity, maxX2 = -Infinity, maxY2 = -Infinity;
      topo.nodes.forEach(function(n){
        minX = Math.min(minX, n.x); minY = Math.min(minY, n.y);
        maxX2 = Math.max(maxX2, n.x + n.w); maxY2 = Math.max(maxY2, n.y + n.h);
      });
      var bboxW = Math.max(1, maxX2 - minX), bboxH = Math.max(1, maxY2 - minY);
      var vw = viewport.clientWidth, vh = viewport.clientHeight;
      var k = clamp(Math.min(vw / bboxW, vh / bboxH) * 0.92, 0.15, 3);
      state.topo.k = k;
      state.topo.x = (vw - bboxW * k) / 2 - minX * k;
      state.topo.y = (vh - bboxH * k) / 2 - minY * k;
      applyTopoTransform();
    };

    // ---- click a topology node -> side panel (AB#377) ----
    document.querySelectorAll('#topo-content .topo-node').forEach(function(g){
      g.addEventListener('click', function(e){
        e.stopPropagation();
        var id = g.getAttribute('data-node-id');
        var node = topoNodes.filter(function(n){ return n.id === id; })[0];
        if(!node) return;
        openPanel(node.label, node.fields);
      });
    });
  }

  // ---- clickable inventory-table rows -> side panel (AB#387, AB#390) ----
  document.querySelectorAll('table.topo-inv-table[data-title="Azure Firewalls"] tbody tr[data-idx]').forEach(function(tr){
    tr.onclick = function(){
      var f = Firewalls[parseInt(tr.getAttribute('data-idx'), 10)];
      if(!f) return;
      openPanel('Azure Firewall — ' + f.name, [
        fld('Name', f.name), fld('Resource group', f.resourceGroup), fld('Subscription', f.subscriptionId), fld('SKU', f.sku),
        fld('Rule collections', 'Not collected — Microsoft.Network/firewallPolicies is not queried by collect.json today.')
      ]);
    };
  });
  document.querySelectorAll('table.topo-inv-table[data-title="VPN gateways"] tbody tr[data-idx]').forEach(function(tr){
    tr.onclick = function(){
      var v = VpnGateways[parseInt(tr.getAttribute('data-idx'), 10)];
      if(!v) return;
      openPanel('VPN gateway — ' + v.name, [
        fld('Name', v.name), fld('Resource group', v.resourceGroup), fld('Gateway type', v.gatewayType),
        fld('SKU', v.sku), fld('Active-active', v.activeActive), fld('BGP', v.bgp)
      ]);
    };
  });
  document.querySelectorAll('table.topo-inv-table[data-title="Private endpoints"] tbody tr[data-idx]').forEach(function(tr){
    tr.onclick = function(){
      var p = PrivateEndpoints[parseInt(tr.getAttribute('data-idx'), 10)];
      if(!p) return;
      openPanel('Private endpoint — ' + p.name, [
        fld('Name', p.name), fld('Resource group', p.resourceGroup),
        fld('Target provider', p.targetProvider), fld('Target type', p.targetType), fld('Target resource Id', p.targetResourceId)
      ]);
    };
  });
}

// ---- Governance (AB#380, AB#391, AB#392, AB#393) ----
function buildMgTree(mgs){
  var byName = {};
  mgs.forEach(function(m){ byName[m.name] = { name: m.name, id: m.id, displayName: m.displayName, parent: m.parent, children: [] }; });
  var roots = [];
  mgs.forEach(function(m){
    var node = byName[m.name];
    if(m.parent && byName[m.parent]){ byName[m.parent].children.push(node); }
    else { roots.push(node); }
  });
  return { roots: roots, byName: byName };
}
function renderMgNode(node){
  var label = esc(node.displayName || node.name);
  var childHtml = node.children.length ? '<ul>'+node.children.map(renderMgNode).join('')+'</ul>' : '';
  return '<li><span class="mg-node clickable-row" data-mg="'+esc(node.name)+'">'+label+'</span>'+childHtml+'</li>';
}

function renderGovernance(){
  var sections = [];

  // ---- management-group hierarchy (AB#380) ----
  if(ManagementGroups.length){
    var tree = buildMgTree(ManagementGroups);
    sections.push('<div class="section-title">Management-group hierarchy</div>'+
      '<ul class="mg-tree">'+tree.roots.map(renderMgNode).join('')+'</ul>');
  }

  // ---- tag chips (AB#391) ----
